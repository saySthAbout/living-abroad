# =========================================================
# Living Abroad - Environment Variables Template
# 이 파일을 .env로 복사한 뒤 실제 값으로 채운다. .env는 git에 커밋하지 않는다.
# =========================================================

# ===== PostgreSQL + pgvector =====
DB_HOST=localhost
DB_PORT=5433
DB_NAME=living_abroad
DB_USER=living_abroad
DB_PASSWORD=change-me

# Docker Compose postgres 이미지용 (pgvector/pgvector:0.8.2-pg18)
POSTGRES_USER=living_abroad
POSTGRES_PASSWORD=change-me
POSTGRES_DB=living_abroad

# ===== Spring Boot (backend) =====
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=change-me-generate-a-strong-random-256-bit-value
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=1209600000

# ===== 이메일 인증 (Gmail SMTP) =====
# Gmail 계정의 앱 비밀번호(일반 로그인 비밀번호 아님)를 발급받아 사용한다:
# Google 계정 → 보안 → 2단계 인증 활성화 → 앱 비밀번호 생성
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change-me@gmail.com
MAIL_PASSWORD=change-me-gmail-app-password
MAIL_FROM=change-me@gmail.com
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_EXPIRATION_MS=86400000

# ===== API Rate Limiting (백엔드, IP당) =====
# 값을 바꾸지 않아도 기본값(아래와 동일)으로 동작한다.
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_GENERAL_LIMIT=60
RATE_LIMIT_GENERAL_WINDOW_MS=60000

# ===== 에러 모니터링 (Sentry) =====
# sentry.io에서 무료 계정 + 프로젝트를 만들고 DSN을 발급받아 채운다. 비워두면
# 각 서비스가 Sentry로 아무것도 보내지 않고 평소처럼 동작한다(에러 트래킹만 비활성화).
# 백엔드/ai-server는 같은 DSN을 공유해도 되고(server_name 태그로 구분됨), 프론트엔드는
# 빌드 타임에 번들에 포함되는 값이라 VITE_ 접두사가 붙은 별도 값이 필요하다 — 같은 DSN을
# 재사용해도 되고, 프론트엔드용 프로젝트를 따로 만들어도 된다.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local

# ===== 에러 알림 (Slack) =====
# Slack 워크스페이스에서 Incoming Webhook을 만들어 URL을 채운다
# (Slack App 생성 → Incoming Webhooks 활성화 → 채널 선택 → URL 복사).
# 이 URL 자체가 비밀값이다(알면 누구나 그 채널에 메시지를 보낼 수 있음) — 절대 프론트엔드
# 코드/커밋에 넣지 않는다. 비워두면 알림을 보내지 않을 뿐 나머지는 평소처럼 동작한다.
SLACK_WEBHOOK_URL=

# ===== FastAPI (ai-server) =====
AI_SERVER_HOST=localhost
AI_SERVER_PORT=8000
AI_SERVER_INTERNAL_URL=http://localhost:8000
# 백엔드 → ai-server 호출 타임아웃. read-timeout은 nginx의 proxy_read_timeout(기본 60초)보다
# 짧게 잡아야, ai-server가 멈춰있을 때 nginx의 날것 504 대신 우리 쪽 503 JSON이 먼저 나간다.
AI_SERVER_CONNECT_TIMEOUT_MS=5000
AI_SERVER_READ_TIMEOUT_MS=45000

# ===== LLM / RAG =====
# 실제 배포에서는 GPU 클라우드(RunPod)의 vLLM(Qwen/Qwen3-8B-AWQ)을 가리키도록 교체한다.
# 로컬 개발 중에는 동일한 OpenAI 호환 API를 제공하는 Ollama로 대체해서 테스트한다.
LLM_API_KEY=ollama-local-no-auth
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=gemma2:latest

# ===== Vue 3 + Vite (frontend) =====
VITE_API_BASE_URL=http://localhost:8080

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173
