# =========================================================
# Living Abroad - Environment Variables Template
# 이 파일을 .env로 복사한 뒤 실제 값으로 채운다. .env는 git에 커밋하지 않는다.
# =========================================================

# ===== PostgreSQL + pgvector =====
DB_HOST=localhost
DB_PORT=5433
DB_NAME=living_abroad
DB_USER=living_abroad
DB_PASSWORD=change-me

# Docker Compose postgres 이미지용 (pgvector/pgvector:0.8.2-pg18)
POSTGRES_USER=living_abroad
POSTGRES_PASSWORD=change-me
POSTGRES_DB=living_abroad

# ===== Spring Boot (backend) =====
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
JWT_SECRET=change-me-generate-a-strong-random-256-bit-value
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=1209600000

# ===== 이메일 인증 (Gmail SMTP) =====
# Gmail 계정의 앱 비밀번호(일반 로그인 비밀번호 아님)를 발급받아 사용한다:
# Google 계정 → 보안 → 2단계 인증 활성화 → 앱 비밀번호 생성
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change-me@gmail.com
MAIL_PASSWORD=change-me-gmail-app-password
MAIL_FROM=change-me@gmail.com
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_EXPIRATION_MS=86400000

# ===== FastAPI (ai-server) =====
AI_SERVER_HOST=localhost
AI_SERVER_PORT=8000
AI_SERVER_INTERNAL_URL=http://localhost:8000

# ===== LLM / RAG =====
# 실제 배포에서는 GPU 클라우드(RunPod)의 vLLM(Qwen/Qwen3-8B-AWQ)을 가리키도록 교체한다.
# 로컬 개발 중에는 동일한 OpenAI 호환 API를 제공하는 Ollama로 대체해서 테스트한다.
LLM_API_KEY=ollama-local-no-auth
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=gemma2:latest

# ===== Vue 3 + Vite (frontend) =====
VITE_API_BASE_URL=http://localhost:8080

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173
